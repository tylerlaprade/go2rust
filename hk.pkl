amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["go-fmt"] = (Builtins.go_fmt) {
        check_first = false
    }
    ["go-vet"] = (Builtins.go_vet) {
        check_first = false
        // Vet package, not individual files — per-file vet can't resolve
        // cross-file symbols (e.g. GetTypeInfo in globals.go used by stdlib.go).
        check = "go vet ./go"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "patch-file"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
